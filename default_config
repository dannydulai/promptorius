    #         icon = '󰁹'
    #         state = ""
    #         col = "battery-full";
    #     } else {
    #         col = pct <= 10 ? "battery-empty" : pct <= 25 ? "battery-low" : "battery-normal"
    #         if (pct > 90) { icon = '󰂂' }
    #         else if (pct > 80) { icon = '󰂁' }
    #         else if (pct > 70) { icon = '󰂀' }
    #         else if (pct > 60) { icon = '󰁿' }
    #         else if (pct > 50) { icon = '󰁾' }
    #         else if (pct > 40) { icon = '󰁽' }
    #         else if (pct > 30) { icon = '󰁼' }
    #         else if (pct > 20) { icon = '󰁻' }
    #         else if (pct > 10) { icon = '󰁺' }
    #         else { icon = '󰂎' }
    #         if (state == "charging") {
    #             state = ` {C("battery-charging")}󱐋`
    #         } else if (state == "discharging") {
    #             state = "";
    #         } else {
    #             state = " " + state;
    #         }
